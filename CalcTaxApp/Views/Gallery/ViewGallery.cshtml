@model GalleryViewModel
@using MyDevHub.Models

@{
    ViewData["Title"] = "ViewGallery";
}

<h1>UploadImage</h1>

<div class="container py-5">

    <!-- Hero Section -->
    <div class="bg-primary text-white rounded-4 shadow p-5 mb-5">

        <div class="row align-items-center">

            <div class="col-md-8">

                <h1 class="fw-bold">
                    Image Gallery
                </h1>

                <p class="lead mb-0">
                    Upload and manage your image collection.
                </p>

            </div>

            <div class="col-md-4 text-end">

                <h2>@Model.Images.Count</h2>

                <p>Total Images</p>

            </div>

        </div>

    </div>

    <!-- Upload Card -->
    <div class="card shadow border-0 mb-5">

        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">
                Upload New Image
            </h4>
        </div>

        <div class="card-body">

            <form asp-controller="Gallery"
                  asp-action="UploadImage"
                  method="post"
                  enctype="multipart/form-data">

                <div class="upload-box">

                    <div class="text-center">

                        <i class="bi bi-cloud-upload display-1 text-primary"></i>

                        <h4 class="mt-3">
                            Select an Image
                        </h4>

                        <input asp-for="File"
                               class="form-control mt-3" />

                    </div>

                </div>

                <div id="previewContainer"
                     class="mt-4 text-center">
                </div>

                <button class="btn btn-primary btn-lg mt-4">
                    Upload Image
                </button>

            </form>

        </div>

    </div>

    <!-- Gallery -->
    <div class="card shadow border-0">

        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">
                Gallery
            </h4>
        </div>

        <div class="card-body">

            <div class="row g-4">

                @foreach (var image in Model.Images)
                {
                    <div class="col-lg-3 col-md-4 col-sm-6">

                        <div class="gallery-card">

                            <img src="@image.FilePath"
                                 class="img-fluid rounded shadow-sm gallery-image"
                                 data-bs-toggle="modal"
                                 data-bs-target="#imageModal"
                                 onclick="showImage('/uploads/@image')" />

                        </div>

                    </div>
                }

            </div>

        </div>

    </div>

</div>

