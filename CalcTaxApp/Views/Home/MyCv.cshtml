
@{
    ViewData["Title"] = "My Cv";
}

<div class="container py-5">

    <!-- Hero Section -->
    <div class="text-black rounded-4 shadow p-5 mb-5">

        <div class="row align-items-center">

            <div class="col-md-8">

                <h1 class="display-5 fw-bold">
                    Agnes Ugochukwu
                </h1>

                <h4 class="mb-3">
                    Backend Developer
                </h4>

                <p class="lead">
                    Experienced in ASP.NET Core, C#, SQL Server,
                    Azure, CQRS, Event-Driven Architecture,
                    and Payroll Systems.
                </p>

                <a href="#" class="btn btn-primary btn-lg">
                    Download CV
                </a>

            </div>

            <div class="col-md-4 text-center">

                <img src="~/images/profile.jpg"
                     class="img-fluid rounded-circle border border-4 border-white shadow"
                     width="220" />

            </div>

        </div>

    </div>

    <!-- Professional Summary -->
    <div class="card shadow-sm border-0 mb-4">

        <div class="card-header text-black">
            <h3 class="mb-0">Professional Summary</h3>
        </div>

        <div class="card-body">

            <p>
                Backend Developer with experience designing,
                developing and maintaining enterprise applications
                using ASP.NET Core, Entity Framework Core and SQL Server.

                Skilled in payroll processing, tax calculations,
                REST APIs, cloud deployments and software architecture.
            </p>

        </div>

    </div>

    <!-- Skills -->
    <div class="card shadow-sm border-0 mb-4">

        <div class="card-header text-black">
            <h3 class="mb-0">Technical Skills</h3>
        </div>

        <div class="card-body">

            <div class="row">

                <div class="col-md-6">

                    <span class="badge bg-primary m-1 p-2">C#</span>
                    <span class="badge bg-primary m-1 p-2">ASP.NET Core</span>
                    <span class="badge bg-primary m-1 p-2">Web API</span>
                    <span class="badge bg-primary m-1 p-2">Entity Framework Core</span>

                </div>

                <div class="col-md-6">

                    <span class="badge bg-primary m-1 p-2">SQL Server</span>
                    <span class="badge bg-primary m-1 p-2">Azure</span>
                    <span class="badge bg-primary m-1 p-2">CQRS</span>
                    <span class="badge bg-primary m-1 p-2">Kafka</span>

                </div>

            </div>

        </div>

    </div>

    <!-- Experience -->
    <div class="card shadow-sm border-0 mb-4">

        <div class="card-header text-black">
            <h3 class="mb-0">Work Experience</h3>
        </div>

        <div class="card-body">

            <div class="border-start border-4 border-primary ps-4">

                <h5>Backend Developer</h5>

                <p class="text-muted mb-1">
                    HR & Payroll Software Company
                </p>

                <small class="text-muted">
                    2023 - Present
                </small>

                <ul class="mt-3">
                    <li>Developed payroll processing modules.</li>
                    <li>Implemented REST APIs using ASP.NET Core.</li>
                    <li>Integrated CQRS architecture patterns.</li>
                    <li>Optimized SQL Server queries and reporting.</li>
                </ul>

            </div>

        </div>

    </div>

    <!-- Education -->
    <div class="card shadow-sm border-0 mb-4">

        <div class="card-header text-black">
            <h3 class="mb-0">Education</h3>
        </div>

        <div class="card-body">

            <h5>Bachelor's Degree</h5>

            <p class="text-muted">
                Computer Science
            </p>

        </div>

    </div>

    <!-- Contact CTA -->
    <div class="bg-primary text-white rounded-4 p-4 text-center">

        <h3>Interested in working together?</h3>

        <p>
            Feel free to reach out for opportunities,
            collaborations or technical discussions.
        </p>

        <a asp-controller="Contact"
           asp-action="Index"
           class="btn btn-light btn-lg">
            Contact Me
        </a>

    </div>

</div>

